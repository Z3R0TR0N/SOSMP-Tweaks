{
    "name": "Soul Eater",
    "description": "You can't eat. Instead, experience orbs refill your hunger.",
    "type": "origins:multiple",
    "nofood": {
        "type": "origins:prevent_item_use",
        "item_condition": {
            "type": "origins:food"
        }
    },
    "transmuteexp": {
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:command",
                    "command": "execute if entity @e[type=minecraft:experience_orb,distance=..4]",
                    "comparison": ">=",
                    "compare_to": 1
                },
                {
                    "type": "origins:food_level",
                    "comparison": "<=",
                    "compare_to": 16
                }
            ]
        },
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:feed",
                    "food": 4,
                    "saturation": 0
                },
                {
                    "type": "origins:execute_command",
                    "command": "kill @e[type=minecraft:experience_orb,limit=1,distance=..5]"
                },
                {
                    "type": "origins:execute_command",
                    "command": "/particle minecraft:sculk_soul ~ ~1 ~ 0.2 0.4 0.2 0.03 10"
                },
                {
                    "type": "origins:play_sound",
                    "sound": "minecraft:block.sculk.spread",
                    "volume": 1,
                    "pitch": 1
                }
            ]
        }
    }
}