{
    "name": "Subdivide",
    "description": "You can consume 10 levels and some of your own vitality to create a sculk catalyst.",
    "type": "origins:active_self",
    "entity_action": {
        "type": "origins:and",
        "actions": [
            {
                "type": "origins:if_else",
                "condition": {
                    "type": "origins:and",
                    "conditions": [
                        {
                            "type": "origins:xp_levels",
                            "comparison": ">=",
                            "compare_to": 10
                        },
                        {
                            "type": "origins:health",
                            "comparison": ">=",
                            "compare_to": 4
                        }
                    ]
                },
                "if_action": {
                    "type": "origins:and",
                    "actions": [
                        {
                            "type": "origins:and",
                            "actions": [
                                {
                                    "type": "origins:add_xp",
                                    "levels": -10
                                },
                                {
                                    "type": "origins:damage",
                                    "amount": 4,
                                    "source": {
                                        "name": "generic",
                                        "bypasses_armor": true,
                                        "magic": true
                                    },
                                    "damage_type": "starve"
                                }
                            ]
                        },
                        {
                            "type": "origins:give",
                            "stack": {
                                "item": "minecraft:sculk_catalyst",
                                "amount": 1
                            },
                            "preferred_slot": "mainhand"
                        },
                        {
                            "type": "origins:and",
                            "actions": [
                                {
                                    "type": "origins:execute_command",
                                    "command": "/particle minecraft:sculk_soul ~ ~1 ~ 0.4 0.5 0.4 0.03 40",
                                    "permission_level": 4
                                },
                                {
                                    "type": "origins:play_sound",
                                    "sound": "minecraft:block.sculk_shrieker.break",
                                    "volume": 1.5,
                                    "pitch": 1
                                }
                            ]
                        }
                    ]
                },
                "else_action": {
                    "type": "origins:play_sound",
                    "sound": "minecraft:block.sculk_sensor.clicking_stop",
                    "volume": 1,
                    "pitch": 1
                }
            }
        ]
    },
    "cooldown": 20,
    "hud_render": {
        "should_render": false
    },
    "key": {
        "key": "key.origins.primary_active"
    }
}